/* 编辑器页面 */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #000000;
}

/* 画布区域 */
.canvas-section {
  background: #030303;
  padding: 24rpx;
}

.canvas-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  background: #1a1a1a;
  border-radius: 8px;
  overflow: hidden;
  border: 1px solid #27272a;
}

.main-canvas {
  /* 尺寸通过 style 动态设置 */
}

.canvas-actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

/* 按钮样式 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  font-size: 14px;
  font-weight: 600;
  line-height: 1.30;
  letter-spacing: -0.16px;
  border-radius: 4px;
  background: transparent;
  border: 1px solid #27272a;
  color: #ffffff;
  transition: all 0.2s ease;
}

.btn-primary {
  background: #eae3d9;
  color: #2c2420;
  border-color: #eae3d9;
}

.btn-secondary {
  background: transparent;
  color: #ffffff;
  border-color: #27272a;
}

.btn-danger {
  background: #ff4444;
  color: #ffffff;
  border-color: #ff4444;
}

.btn-text {
  font-size: 14px;
  font-weight: 600;
  line-height: 1.30;
  letter-spacing: -0.16px;
}

.btn-sm {
  padding: 8rpx 16rpx;
  font-size: 12px;
}

/* 工具栏 */
.toolbar {
  display: flex;
  background: #030303;
  padding: 16rpx 24rpx;
  gap: 12rpx;
  border-bottom: 1px solid #27272a;
}

.tool-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 4px;
  background: transparent;
  border: 1px solid #27272a;
  transition: all 0.2s ease;
}

.tool-item.active {
  background: #eae3d9;
  border-color: #eae3d9;
}

.tool-item.active .tool-label {
  color: #2c2420;
}

.tool-label {
  font-size: 11px;
  font-weight: 450;
  line-height: 1.30;
  letter-spacing: normal;
  text-transform: uppercase;
  color: #767d88;
}

/* 控制面板 */
.control-panel {
  flex: 1;
  background: #030303;
  overflow: hidden;
}

.panel-content {
  padding: 24rpx;
  height: 100%;
  overflow-y: auto;
  animation: panelFadeIn 0.2s ease;
}

@keyframes panelFadeIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.panel-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.panel-title {
  font-size: 20px;
  font-weight: 400;
  line-height: 1.00;
  letter-spacing: normal;
  color: #ffffff;
  flex: 1;
}

/* 拼接布局开关（嵌入波点面板） */
.layout-toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  background: #1a1a1a;
  border: 1px solid #27272a;
  border-radius: 8px;
}

.layout-toggle-info {
  flex: 1;
  margin-right: 16rpx;
}

.layout-toggle-info .panel-title {
  margin-bottom: 2rpx;
  font-size: 15px;
}

.tip-text-inline {
  font-size: 11px;
  font-weight: 400;
  line-height: 1.35;
  color: #555;
  display: block;
}

.layout-options {
  margin-bottom: 12rpx;
}

/* 提示文字 */
.tip-text {
  font-size: 13px;
  font-weight: 400;
  line-height: 1.30;
  letter-spacing: -0.16px;
  color: #767d88;
  margin-bottom: 24rpx;
  display: block;
}

/* 空状态提示 */
.empty-hint {
  padding: 48rpx 24rpx;
  text-align: center;
}

.empty-text {
  font-size: 14px;
  font-weight: 400;
  line-height: 1.40;
  color: #767d88;
}

/* 控制网格 */
.control-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.control-item {
  width: calc(50% - 8rpx);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.control-item.full-width {
  width: 100%;
  flex-direction: column;
  align-items: flex-start;
}

.control-label {
  font-size: 14px;
  font-weight: 500;
  line-height: 1.25;
  letter-spacing: 0.35px;
  text-transform: uppercase;
  color: #767d88;
  min-width: 80rpx;
}

.picker-btn {
  flex: 1;
  padding: 12rpx 16rpx;
  background: #1a1a1a;
  border: 1px solid #27272a;
  border-radius: 4px;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.30;
  letter-spacing: -0.16px;
  color: #ffffff;
  text-align: center;
}

/* 滑块组 */
.slider-group {
  margin-bottom: 24rpx;
}

.slider-item {
  margin-bottom: 24rpx;
}

.slider-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.slider-label {
  font-size: 14px;
  font-weight: 500;
  line-height: 1.25;
  letter-spacing: 0.35px;
  text-transform: uppercase;
  color: #767d88;
  margin-bottom: 12rpx;
  display: block;
}

/* 确保滑块填满容器宽度 */
.slider-item slider,
.control-item slider {
  width: 100%;
}

.slider-header .slider-label {
  margin-bottom: 0;
}

.slider-hint {
  font-size: 11px;
  font-weight: 450;
  line-height: 1.30;
  letter-spacing: normal;
  color: #555;
}

/* 颜色相关 */
.color-swatch {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 1px solid #27272a;
}

.color-swatch.large {
  width: 80rpx;
  height: 80rpx;
}

.color-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.color-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.color-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 调色板 */
.color-palette {
  margin-bottom: 24rpx;
}

.palette-scroll {
  white-space: nowrap;
  margin-top: 12rpx;
}

.palette-item {
  display: inline-block;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  border: 3rpx solid transparent;
}

.palette-item.selected {
  border-color: #eae3d9;
  transform: scale(1.1);
}

/* 分类标签 */
.category-tabs {
  white-space: nowrap;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
}

.tab {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  background: transparent;
  border: 1px solid #27272a;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 450;
  line-height: 1.30;
  letter-spacing: normal;
  text-transform: uppercase;
  color: #767d88;
}

.tab.active {
  background: #eae3d9;
  color: #2c2420;
  border-color: #eae3d9;
}

/* 素材列表 */
.material-list {
  height: 240rpx;
  margin-bottom: 24rpx;
}

.material-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.material-item {
  width: calc(25% - 9rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.material-preview {
  width: 100%;
  aspect-ratio: 1;
  background: #1a1a1a;
  border-radius: 8px;
  border: 1px solid #27272a;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
}

.material-item.selected .material-preview {
  border-color: #eae3d9;
  background: #27272a;
}

.material-preview.builtin {
  background: #1a1a1a;
}

.builtin-icon {
  font-size: 48rpx;
  color: #ffffff;
}

.material-img {
  width: 80%;
  height: 80%;
}

.material-name {
  font-size: 11px;
  font-weight: 450;
  line-height: 1.30;
  letter-spacing: normal;
  text-transform: uppercase;
  color: #767d88;
  margin-top: 8rpx;
  text-align: center;
}

/* 素材控制 */
.material-controls {
  background: #1a1a1a;
  border: 1px solid #27272a;
  border-radius: 8px;
  padding: 24rpx;
}

/* 条纹控制 */
.stripe-controls {
  margin-bottom: 24rpx;
}

.photo-section {
  margin-bottom: 24rpx;
}

/* 颜色选择器弹窗 */
.color-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background: #1a1a1a;
  border: 1px solid #27272a;
  border-radius: 8px;
  padding: 40rpx;
  z-index: 1001;
}

.modal-title {
  font-size: 20px;
  font-weight: 400;
  line-height: 1.00;
  letter-spacing: normal;
  text-align: center;
  margin-bottom: 30rpx;
  color: #ffffff;
}

.preset-colors {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.preset-color {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 1px solid #27272a;
}

.custom-color {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.custom-color input {
  flex: 1;
  padding: 12rpx 16rpx;
  background: #1a1a1a;
  border: 1px solid #27272a;
  border-radius: 4px;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.30;
  letter-spacing: -0.16px;
  color: #ffffff;
}

.custom-color input:focus {
  border-color: #eae3d9;
  outline: none;
}

/* 输入框样式 */
.input {
  background: #1a1a1a;
  border: 1px solid #27272a;
  border-radius: 4px;
  padding: 12rpx 16rpx;
  color: #ffffff;
  font-size: 16px;
  line-height: 1.30;
  letter-spacing: -0.16px;
}

.input:focus {
  border-color: #eae3d9;
  outline: none;
}
